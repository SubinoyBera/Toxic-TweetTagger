{
    "version": 2,
    "builds": [
        {
            "src": "frontend/app.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "runtime": "python3.11"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/frontend/app.py"
        }
    ]
}